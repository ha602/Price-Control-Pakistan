# Supabase Configuration
# Dashboard → Settings → API: Project URL + anon public key (same project only).
# Reference ID is the subdomain: https://<reference-id>.supabase.co
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# App phase: `1` (default) = static cities in config; `2` = cities from DB + Area monitors tab + SMTP alerts.
# Set before `npm run build` — Vite injects window.__APP_PHASE__ into each HTML file.
# VITE_APP_PHASE=1

# Admins: create users under Authentication → Users, then add a row to
# public.staff_profiles with that user's UUID (see supabase-setup.sql).
